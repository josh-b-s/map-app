{
  "name": "mapapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "preprocess-gtfs": "ts-node --project tsconfig.scripts.json scripts/preprocess-gtfs.ts",
    "postinstall": "patch-package",
    "prebuild": "npx expo prebuild",
    "build:rust": "cd modules/gtfs-importer/rust && npx ubrn build android --and-generate",
    "rebuild:android": "npm run build:rust && npx expo run:android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@mapapp/gtfs-importer": "file:modules/gtfs-importer",
    "@mapbox/polyline": "^1.2.1",
    "@op-engineering/op-sqlite": "^17.1.2",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.11.2",
    "expo": "~54.0.29",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.12",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.10",
    "expo-location": "^19.0.8",
    "expo-router": "~6.0.19",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.29.1",
    "react-native-maps": "1.20.1",
    "react-native-quick-base64": "^3.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-zip-archive": "^9.0.0",
    "react-redux": "^9.2.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "uniffi-bindgen-react-native": "^0.31.0-3"
  },
  "private": true
}
